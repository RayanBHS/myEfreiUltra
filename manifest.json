{
  "manifest_version": 3,
  "name": "MyEfrei Custom Interface",
  "version": "1.0",
  "description": "Amélioration et personnalisation de l'interface de MyEfrei.",
  "content_scripts": [
    {
      "matches": [
        "*://auth.efrei.fr/*",
        "*://auth.myefrei.fr/*"
      ],
      "css": ["login.css"],
      "js": ["login.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.efrei.fr/*",
        "*://*.myefrei.fr/*"
      ],
      "exclude_matches": [
        "*://auth.efrei.fr/*",
        "*://auth.myefrei.fr/*"
      ],
      "css": ["pdfViewer.css", "portal.css", "grades.css", "planning.css", "moodle.css"],
      "js": ["lib/pdf.min.js", "pdfViewer.js", "portal.js", "grades.js", "planning.js", "moodle.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "img/logoEfrei.png",
        "img/logoMyEfrei.png",
        "img/logoEfreiDepInf.png",
        "img/Campus.png",
        "img/tourAssas.png",
        "Police/Alliance No.2 Bold.otf",
        "Police/Alliance No.2 Regular.otf",
        "lib/pdf.worker.min.js"
      ],
      "matches": ["*://*.efrei.fr/*", "*://*.myefrei.fr/*"]
    }
  ],
  "action": {
    "default_title": "MyEfrei Custom Interface"
  }
}
