{
  "manifest_version": 3,
  "name": "MyEfrei ULTRA",
  "version": "1.0",
  "description": "Amélioration et personnalisation de l'interface de MyEfrei.",
  "icons": {
    "16": "img/logoEfreiDepInf.png",
    "48": "img/logoEfreiDepInf.png",
    "128": "img/logoEfreiDepInf.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.efrei.fr/*",
    "*://*.myefrei.fr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://auth.efrei.fr/*",
        "*://auth.myefrei.fr/*"
      ],
      "css": ["login.css"],
      "js": ["fonts.js", "login.js", "gamepad.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.efrei.fr/*",
        "*://*.myefrei.fr/*"
      ],
      "exclude_matches": [
        "*://auth.efrei.fr/*",
        "*://auth.myefrei.fr/*"
      ],
      "css": [
        "portal.css",
        "dashboard.css",
        "grades.css",
        "planning.css",
        "moodle.css",
        "pdfViewer.css",
        "absences.css",
        "news.css",
        "article.css",
        "campus.css",
        "documents.css",
        "lxp.css",
        "rooms.css",
        "guest.css",
        "resources.css",
        "contacts.css",
        "lib/leaflet/leaflet.css"
      ],
      "js": [
        "fonts.js",
        "lib/pdf.min.js",
        "lib/leaflet/leaflet.js",
        "portal.js",
        "dashboard.js",
        "grades.js",
        "planning.js",
        "calendars.js",
        "moodle.js",
        "pdfViewer.js",
        "absences.js",
        "news.js",
        "article.js",
        "campus.js",
        "documents.js",
        "lxp.js",
        "rooms.js",
        "guest.js",
        "resources.js",
        "contacts.js",
        "gamepad.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "file:///*",
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["sync-portal.js", "gamepad.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "img/logoEfrei.png",
        "img/logoMyEfrei.png",
        "img/logoEfreiDepInf.png",
        "img/Campus.png",
        "img/tourAssas.png",
        "img/chouetteTechnicien.png",
        "Police/*",
        "lib/pdf.worker.min.js",
        "lib/leaflet/images/*"
      ],
      "matches": ["*://*.efrei.fr/*", "*://*.myefrei.fr/*"]
    }
  ],
  "action": {
    "default_title": "MyEfrei Custom Interface",
    "default_icon": {
      "16": "img/logoEfreiDepInf.png",
      "48": "img/logoEfreiDepInf.png",
      "128": "img/logoEfreiDepInf.png"
    }
  }
}
